# --- Telegram ---
# Токен бота от @BotFather
BOT_TOKEN=123456:CHANGE_ME
# ID администраторов через запятую (кому разрешено управлять ботом и кому идут уведомления)
ADMIN_IDS=111111111,222222222

# --- Яндекс Маркет Partner API ---
# Базовый URL API (менять не нужно)
MARKET_API_BASE=https://api.partner.market.yandex.ru

# Магазин №1
SHOP1_NAME=Магазин 1
SHOP1_API_KEY=CHANGE_ME_API_KEY_1
SHOP1_BUSINESS_ID=0
SHOP1_CAMPAIGN_ID=0

# Магазин №2
SHOP2_NAME=Магазин 2
SHOP2_API_KEY=CHANGE_ME_API_KEY_2
SHOP2_BUSINESS_ID=0
SHOP2_CAMPAIGN_ID=0

# --- Поллер ---
# Период опроса заказов в секундах
POLL_INTERVAL_SECONDS=45
# За сколько последних часов запрашивать заказы при опросе
POLL_LOOKBACK_HOURS=48

# --- Тест-режим ---
# true  — обрабатывать ТОЛЬКО тестовые заказы Маркета (fake=true), без платы.
#         Настоящие заказы при этом игнорируются. Удобно для отладки.
# false — боевой режим: обрабатывать только настоящие заказы.
TEST_MODE=false

# --- Выдача ---
# Срок действия ключей (дней от даты выдачи) для activate_till, если у товара не задан свой
DEFAULT_ACTIVATE_DAYS=30

# --- База данных ---
DATABASE_URL=sqlite+aiosqlite:///./data/service.db
